# ─── Public URLs (visible to browser) ──────────────────────
# Local dev:  http://localhost:3000
# Production: http://YOUR_SERVER_IP:3000  or  https://tracker.yourdomain.com
PUBLIC_URL=http://localhost:3000
WS_URL=ws://localhost:3000

# Port nginx binds to on the host (80 if free, else 3000 or any other)
NGINX_PORT=3000

# Timezone used by the server to evaluate schedule slots. Must match the
# wall-clock zone you type into the schedule UI. Examples:
#   Asia/Kolkata   (IST,  UTC+5:30 — default)
#   America/New_York, Europe/London, etc.
TZ=Asia/Kolkata

# ─── Database ──────────────────────────────────────────────
POSTGRES_USER=gst
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=gst_tracker

# ─── Push Notifications (optional) ─────────────────────────
# Generate with:  npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:you@example.com
